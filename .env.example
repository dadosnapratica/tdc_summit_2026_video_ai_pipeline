# Copiar para `workshop/.env` (opcional) OU para `.env` na raiz.
# Este template é **auto-contido** para quando `workshop/` for publicado como repo.
#
# Carregamento no BFF:
# - `workshop/.env` tem prioridade
# - depois `.env` na raiz (se existir)
#
# Guia completo (monorepo): docs/CONFIGURATION.md

# =============================================================================
# BASES (workshop)
# =============================================================================
# PROJECT_BASE_PATH — caminho absoluto da raiz do REPO DO WORKSHOP (onde existe a pasta `nas/`).
# LOCAL_SERVICES_BASE_URL — host onde correm Ollama e ComfyUI. Ex.: http://192.168.15.150
# MODELS_BASE_PATH — pasta pai dos modelos Kokoro/Piper (não versionar binários).

PROJECT_BASE_PATH=/caminho/absoluto/para/workshop_repo
LOCAL_SERVICES_BASE_URL=http://192.168.15.150
MODELS_BASE_PATH=${PROJECT_BASE_PATH}/models

# =============================================================================
# STORAGE (workshop)
# =============================================================================
# Jobs do pipeline: uma subpasta por job_id em `nas/jobs/` (conteúdo gerado; gitignored).

PIPELINE_JOBS_PATH=${PROJECT_BASE_PATH}/nas/jobs

# =============================================================================
# LLM (Ollama)
# =============================================================================
# Se o workshop acessar via Tunnel + JWT, use o proxy do jwt_broker:
# JWT_BROKER_PUBLIC_URL=https://jwt-broker.ideiasfactory.tech
# OLLAMA_BASE_URL=${JWT_BROKER_PUBLIC_URL}/v1/proxy/ollama
OLLAMA_BASE_URL=${LOCAL_SERVICES_BASE_URL}:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_S=180
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.7

# =============================================================================
# LLM (OpenAI)
# =============================================================================

# OPEN AI KEYS
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-proj-1234567890
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_S=180
# OPENAI_TEMPERATURE=0.7
# OPENAI_PROVIDER=openai
# OPENAI_PROVIDER_DEFAULT=openai
# OPENAI_PROVIDER_FALLBACK=openai
# OPENAI_PROVIDER_FALLBACK_DEFAULT=openai

# =============================================================================
# ComfyUI / visual
# =============================================================================
# No GPU, o ComfyUI tem de estar acessível no URL que usas abaixo: em WSL costuma ser
# necessário COMFYUI_LISTEN=0.0.0.0 em server/comfyui/.env para 192.168.x.x:8188 e para o
# jwt_broker (Docker) — ver set-ambiente-workshop/server/comfyui/CONFIGURACAO.md §7.
# Se o workshop acessar via Tunnel + JWT, use o proxy do jwt_broker:
# COMFYUI_BASE_URL=${JWT_BROKER_PUBLIC_URL}/v1/proxy/comfyui
COMFYUI_BASE_URL=${LOCAL_SERVICES_BASE_URL}:8188
COMFYUI_MODEL=dreamshaperXL_v21TurboDPMSDE.safetensors
ANIMATEDIFF_MODEL=animatediff_v3.ckpt
IMG2IMG_STRENGTH=0.45
ANIMATEDIFF_FRAMES=16
ANIMATEDIFF_FPS=8
COMFYUI_TIMEOUT_S=900
VISUAL_FALLBACK_CLIP_SECONDS=2.0
# Laboratório (UI): estado inicial do checkbox «Usar ComfyUI». 1=tentar AnimateDiff; 0=só ffmpeg.
VISUAL_USE_COMFYUI_DEFAULT=1

# Laboratório: o visual_agent só usa ComfyUI se ``config/comfyui_animatediff_workflow.json`` no
# monorepo NÃO tiver "__PLACEHOLDER__": true (export real do grafo AnimateDiff/img2img).
# Caso contrário mode=ffmpeg_fallback mesmo com o servidor ComfyUI online. Para enviar imagens:
# COMFYUI_INPUT_METHOD=upload ou COMFYUI_INPUT_METHOD=copy + COMFYUI_INPUT_DIR visível pelo ComfyUI.

# =============================================================================
# TTS
# =============================================================================
TTS_PROVIDER=kokoro,piper
TTS_PROVIDER_DEFAULT=piper
# Piper model
PIPER_MODEL=${MODELS_BASE_PATH}/piper/pt_BR-faber-medium.onnx
# Ex.: /opt/homebrew/bin/piper (Mac) ou /usr/bin/piper (Linux) — ajuste ao seu ambiente
PIPER_EXECUTABLE=piper
PIPER_VOICES_DIR=${MODELS_BASE_PATH}/piper
# Kokoro model
KOKORO_MODEL=${MODELS_BASE_PATH}/kokoro/kokoro-v1.0.int8.onnx
KOKORO_VOICES=${MODELS_BASE_PATH}/kokoro/voices-v1.0.bin
KOKORO_VOICE=pf_dora
KOKORO_LANG=pt
KOKORO_SPEED=1.0

# =============================================================================
# Assets (opcional no workshop)
# =============================================================================
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
IMAGE_RESEARCH_SOURCES=pexels,pixabay,unsplash,nasa,wikimedia
ASSET_DEFAULT_STYLE_GUIDE=
ASSET_RESEARCH_PREFERENCE=video_first
ASSET_CURATION=llm
ASSET_PER_SOURCE=4
ASSET_HTTP_TIMEOUT=25
PIXABAY_MAX_ATTEMPTS=3
PIXABAY_BACKOFF_S=1.0

# =============================================================================
# YouTube (opcional; lab/publish)
# =============================================================================
# Read Only YouTube API KEY para busca de tendencias e videos mais vistos
YOUTUBE_API_KEY=

# Variáveis de ambiente do Google para identificar sua aplicação para fazer o upload do video
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Pasta local dos tokens OAuth (absoluto recomendado em deploy). Por defeito: workshop/config/youtube_auth/
# (O caminho antigo workshop/bff/.youtube_auth deixou de ser lido — migrar manualmente se ainda existir.)
# YOUTUBE_AUTH_DIR=/caminho/absoluto/workshop/config/youtube_auth
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_OAUTH_REDIRECT_URL=

YOUTUBE_REGION_CODE=BR
YOUTUBE_CATEGORY_ID=28
YOUTUBE_MAX_TRENDING_RESULTS=10
PUBLISH_PRIVACY_STATUS=private
SKIP_YOUTUBE_UPLOAD=0

# =============================================================================
# Lab extras
# =============================================================================

# =============================================================================
# Logging (Lab / BFF)
# =============================================================================
# LOG_LEVEL=INFO
# LOG_COLORED=1
# LOG_DIR=logs
# LOG_KEEP_DAYS=14
#
# Debug forense (sensível): request/response payloads em JSONL (somente arquivo).
# DEBUG_TRACE_LOG=0
# DEBUG_TRACE_MAX_BODY_BYTES=65536
#
# TTS: pausa entre parágrafos (texto puro; funciona para Kokoro/Piper).
# TTS_PARAGRAPH_PAUSE_TOKEN=...
IMAGE_RESEARCH_RANKER=llm
IMAGE_RESEARCH_ASPECT_TOLERANCE=0.12

# Proxy de credenciais (/v1/proxy/*) — recomendado apontar para o jwt_broker
LAB_CREDENTIALS_BASE_URL=
WORKSHOP_ACCESS_TOKEN=

# Validação na subida do BFF (opcional)
# WORKSHOP_CONFIG_STRICT=1

# Probe do broker JWT no health (opcional)
# Ex.: http://192.168.15.150:8835 (interno) ou https://jwt-broker.ideiasfactory.tech (tunnel)
JWT_BROKER_PUBLIC_URL=

# Timeouts (connect, read) em segundos para GET /health/live no broker e em LAB_CREDENTIALS_BASE_URL.
# Aumente se /health reportar «Read timed out» com o host público (Cloudflare/túnel).
# HEALTH_REMOTE_PROBE_CONNECT_S=4
# HEALTH_REMOTE_PROBE_READ_S=12

