# Carregamento no BFF:
# - `workshop/.env` tem prioridade
# - depois `.env` na raiz (se existir)
#
# Guia completo (monorepo): docs/CONFIGURATION.md

# =============================================================================
# BASES (workshop)
# =============================================================================
# PROJECT_BASE_PATH — caminho absoluto da raiz do REPO DO WORKSHOP (onde existe a pasta `nas/`).
# LOCAL_SERVICES_BASE_URL — host onde correm Ollama e ComfyUI. Ex.: http://192.168.15.150
# MODELS_BASE_PATH — pasta pai dos modelos Kokoro/Piper (não versionar binários).

PROJECT_BASE_PATH=/tdc_summit_2026/video_ai_pipeline/workshop
MODELS_BASE_PATH=${PROJECT_BASE_PATH}/models

# Substitua com o token de acordo com a posicao da sua maquina
# consulte o token no arquivo workshop_tokens_20260424.json 
WORKSHOP_ACCESS_TOKEN=

# =============================================================================
# STORAGE (workshop)
# =============================================================================
# Jobs do pipeline: uma subpasta por job_id em `nas/jobs/` (conteúdo gerado; gitignored).

PIPELINE_JOBS_PATH=${PROJECT_BASE_PATH}/nas/jobs

# =============================================================================
# LLM (Ollama)
# =============================================================================
OLLAMA_BASE_URL=https://ollama.ideiasfactory.ddns.net #${LOCAL_SERVICES_BASE_URL}:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_S=180
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.7

# =============================================================================
# LLM (OpenAI)
# =============================================================================
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-proj-1234567890
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_S=180
# OPENAI_TEMPERATURE=0.7
# OPENAI_PROVIDER=openai
# OPENAI_PROVIDER_DEFAULT=openai
# OPENAI_PROVIDER_FALLBACK=openai
# OPENAI_PROVIDER_FALLBACK_DEFAULT=openai

# =============================================================================
# ComfyUI / visual
# =============================================================================
COMFYUI_BASE_URL=https://comfyui.ideiasfactory.tech #${LOCAL_SERVICES_BASE_URL}:8188
# copy = colocar imagens em COMFYUI_INPUT_DIR (mesmo disco ou NFS montado no BFF).
# upload = POST /upload/image para o ComfyUI — útil quando o BFF está noutra máquina sem NFS (comfyui.ideiasfactory… precisa URL http(s) válida para requests).
COMFYUI_INPUT_METHOD=upload
COMFYUI_INPUT_DIR=
COMFYUI_MODEL=dreamshaperXL_v21TurboDPMSDE.safetensors
ANIMATEDIFF_MODEL=animatediff_v3.ckpt
IMG2IMG_STRENGTH=0.45
ANIMATEDIFF_FRAMES=16
ANIMATEDIFF_FPS=8
COMFYUI_TIMEOUT_S=900
VISUAL_FALLBACK_CLIP_SECONDS=2.0

# =============================================================================
# TTS
# =============================================================================
TTS_PROVIDER=kokoro,piper
TTS_PROVIDER_DEFAULT=piper
# Piper model
PIPER_MODEL=${MODELS_BASE_PATH}/piper/pt_BR-faber-medium/pt_BR-faber-medium.onnx
PIPER_EXECUTABLE=${PROJECT_BASE_PATH}/.venv/bin/piper
PIPER_VOICES_DIR=${MODELS_BASE_PATH}/piper
# Kokoro model
KOKORO_MODEL=${MODELS_BASE_PATH}/kokoro/kokoro-v1.0.int8.onnx
KOKORO_VOICES=${MODELS_BASE_PATH}/kokoro/voices-v1.0.bin
KOKORO_VOICE=pf_dora
KOKORO_LANG=pt
KOKORO_SPEED=1.0

# =============================================================================
# Assets (opcional no workshop)
# =============================================================================
#IMAGE_RESEARCH_SOURCES=pexels,pixabay,unsplash,nasa,wikimedia
IMAGE_RESEARCH_SOURCES=pexels,pixabay
ASSET_DEFAULT_STYLE_GUIDE="cinematic documentary, realistic, high detail, 16:9, 1080p, no text, no logos, no watermarks"
ASSET_RESEARCH_PREFERENCE=video_first
ASSET_CURATION=llm
ASSET_PER_SOURCE=4
ASSET_HTTP_TIMEOUT=25

# Pixabay KEYS
PIXABAY_MAX_ATTEMPTS=3
PIXABAY_BACKOFF_S=1.0

# =============================================================================
# YouTube (opcional; lab/publish)
# =============================================================================
# .env — YouTube Data API v3

# Variáveis de ambiente do Google para identificar sua aplicação para fazer o upload do video
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_OAUTH_REDIRECT_URL=

# Parâmetros de uso
YOUTUBE_CATEGORY_ID=28      # Ciência e Tecnologia
YOUTUBE_REGION_CODE=BR
YOUTUBE_MAX_TRENDING=10
PUBLISH_PRIVACY_STATUS=private
SKIP_YOUTUBE_UPLOAD=0

# =============================================================================
# Lab extras
# =============================================================================
IMAGE_RESEARCH_RANKER=ollama
IMAGE_RESEARCH_ASPECT_TOLERANCE=0.12

# Proxy de credenciais (opcional)
LAB_CREDENTIALS_BASE_URL=https://lab.ideiasfactory.ddns.net

# Validação na subida do BFF (opcional)
# WORKSHOP_CONFIG_STRICT=1

# Probe do broker JWT no health (opcional)
JWT_BROKER_PUBLIC_URL=https://jwt-broker.ideiasfactory.tech

